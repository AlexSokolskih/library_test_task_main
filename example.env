DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=document_description
DOCUMENT_DESCRIPTION_TOKEN=change-me
PORT=3000

# NDJSON: размер очереди objectMode Transform (меньше — меньше пик RAM при медленном клиенте)
NDJSON_TRANSFORM_HIGH_WATER_MARK=16

# Выгрузка: batchSize для pg-query-stream (через пул TypeORM)
EXPORT_STREAM_BATCH_SIZE=1000
